# docker compose 로컬 실행 시 필요한 값. 이 파일을 복사해서 .env로 만들고 값을 채우세요.
#   cp .env.example .env
#
# 비밀번호는 평문으로 넣으면 앱이 기동할 때 자동으로 BCrypt 해시화합니다. 직접 해시를
# 만들 필요 없음. (이미 해시를 갖고 있다면 ADMIN_PASSWORD_HASH를 대신 써도 됩니다 —
# 단, 그 값은 $ 문자가 많아서 docker compose가 .env를 읽을 때 오작동하지 않도록
# $ 하나마다 $$ 로 이스케이프해야 합니다. 웬만하면 ADMIN_PASSWORD를 쓰는 걸 권장.)

ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# NVIDIA NIM 기반 AI 초안 생성 (핵심 역량 / 공부 정리 / 이력·경력 공통)
# https://build.nvidia.com 에서 발급한 키를 입력한 뒤 기능별로 활성화하세요.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com
NVIDIA_MODEL=qwen/qwen3.5-122b-a10b
NVIDIA_MAX_OUTPUT_TOKENS=8192
# response_format(json_object)을 지원하는 모델에서만 true (Qwen3.5 NIM은 미지원)
# NVIDIA_JSON_RESPONSE_FORMAT=false
COMPETENCY_AI_ENABLED=false
STUDY_AI_ENABLED=false
EXPERIENCE_AI_ENABLED=false

# 이미지 업로드용 오브젝트 스토리지 (S3 호환)
# 로컬은 docker-compose가 MinIO 컨테이너와 기본값을 이미 다 채워주므로 보통 .env에
# 아래 값을 따로 적을 필요가 없습니다. 운영(Oracle Object Storage)에 배포할 때만
# K8s 쪽 설정(deploy/k8s/overlays/prod)에서 실제 값으로 덮어씁니다.
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_PRESIGNED_ENDPOINT=http://localhost:9000
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=self-intro-images
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_PATH_STYLE_ACCESS=true
# STORAGE_PRESIGNED_TTL_SECONDS=300
# STORAGE_PUBLIC_BASE_URL=http://localhost:9000/self-intro-images
